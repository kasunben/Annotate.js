{
  "name": "annotate-server",
  "version": "0.5.15",
  "description": "Lightweight inline annotation and threaded comments for any web page — added via a single <script> tag.",
  "main": "server/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node server/index.js",
    "build": "esbuild assets/js/annotate.js --bundle --minify --format=iife --inject:assets/js/trystero-shim.js --define:__ANNOTATE_VERSION__=\"\\\"$(node -p \"require('./package.json').version\")\\\"\" --outfile=annotate.min.js",
    "kill-port": "bash -c 'pid=$(lsof -nP -iTCP:3000 -sTCP:LISTEN 2>/dev/null | grep LISTEN | awk \"{print \\$2}\" | head -1); if [ -n \"$pid\" ]; then kill -9 $pid && echo \"Port 3000 freed (PID $pid)\"; else echo \"Port 3000 is already free\"; fi'",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop annotate",
    "pm2:restart": "pm2 restart annotate",
    "pm2:logs": "pm2 logs annotate",
    "test": "vitest run --config vitest.config.mjs",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:unit": "vitest run --config vitest.config.mjs tests/unit",
    "test:integration": "vitest run --config vitest.config.mjs tests/integration",
    "test:e2e": "playwright test --config playwright.config.mjs",
    "test:e2e:headed": "playwright test --config playwright.config.mjs --headed",
    "test:coverage": "vitest run --config vitest.config.mjs --coverage",
    "test:all": "vitest run --config vitest.config.mjs --coverage && playwright test --config playwright.config.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.0",
    "supertest": "^7.2.2",
    "trystero": "^0.21.0",
    "vitest": "^3.2.4",
    "ws": "^8.21.0"
  }
}
